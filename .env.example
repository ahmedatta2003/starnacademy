# Supabase Configuration (client-side, safe to expose)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

# Site Configuration
VITE_SITE_URL=https://your-domain.com
VITE_SITE_NAME=Star Academy

# WARNING:
# NEVER add SUPABASE_SERVICE_ROLE_KEY (or any secret) with the VITE_ prefix.
# The VITE_ prefix bundles values into client code and exposes them in the browser.
# Service role / private keys must only be used server-side (Edge Functions),
# read via Deno.env.get('SUPABASE_SERVICE_ROLE_KEY').
